{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(cargo *)",
      "Bash(make *)",
      "Bash(go *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(pwd)",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Agent",
      "WebFetch",
      "WebSearch",
      "ToolSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prefer-dedicated-tools.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-budget.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_MAX_TOOL_CALLS": "500",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  }
}
